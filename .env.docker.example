# =============================================================================
# Docker / CI — mismas variables que .env.example; en imagen suele usarse URL absoluta.
#
#   docker build \
#     --build-arg PUBLIC_API_URL=http://api-gateway:3000/api \
#     --build-arg PUBLIC_KIOSK_API_KEY=... \
#     --build-arg PUBLIC_WEGLOT_API_KEY=... \
#     --build-arg PUBLIC_SENTRY_DSN=... \
#     --build-arg SENTRY_AUTH_TOKEN=... \
#     -t kiora-client .
# =============================================================================

PUBLIC_API_URL=http://host.docker.internal:3000/api
PUBLIC_KIOSK_API_KEY=
PUBLIC_WEGLOT_API_KEY=
