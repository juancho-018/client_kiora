# =============================================================================
# client_kiora — misma convención que PROYECTO_KIORAPP (Panel)
# Copia: cp .env.example .env
# Puedes reutilizar en el kiosco los mismos valores de PUBLIC_WEGLOT_* y
# PUBLIC_SENTRY_DSN que tengas en el .env del panel, salvo que quieras
# proyectos o claves distintos en Sentry.
# =============================================================================

# --- API Gateway (mismo nombre que en el panel) ---
# Recomendado en local (kiosco en :9095, gateway en :3000): usa ruta relativa y evita CORS.
#   PUBLIC_API_URL=/api
# Si copias http://localhost:3000/api del panel, el cliente igual usará /api en localhost
# (detección automática). Para otros dominios, URL absoluta solo si CORS lo permite en el gateway.
# Tras cambiar PUBLIC_API_URL hay que volver a ejecutar `npm run build`.
PUBLIC_API_URL=/api

# --- Kiosco: pedidos sin JWT (solo en client_kiora; debe coincidir con KIOSK_API_KEY del gateway) ---
PUBLIC_KIOSK_API_KEY=

# --- Weglot (opcional; mismo panel / mismo PUBLIC_WEGLOT_API_KEY) ---
PUBLIC_WEGLOT_API_KEY=

# --- Sentry — mismo DSN público que el panel (opcional) ---
# Si más adelante añades @sentry/astro aquí, usa el mismo proyecto o uno nuevo.
PUBLIC_SENTRY_DSN=

# --- Sentry — solo build / subida de source maps (no va al navegador) ---
# Igual que en PROYECTO_KIORAPP al ejecutar astro build con integración Sentry.
SENTRY_AUTH_TOKEN=
